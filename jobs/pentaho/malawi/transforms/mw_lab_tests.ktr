    <connection>Warehouse</connection>
    <sql>/*
	Extract Viral Load Less Than Limit
*/
select 		o.patient_id,
			o.encounter_id,
			o.obs_date as date_collected,
			o.date_created as date_result_entered,
			CONCAT('&lt;',o.value_numeric) as result_exception
from        omrs_obs o
where 		o.concept = 'Less than limit'
order by 	o.patient_id, o.encounter_id</sql>
